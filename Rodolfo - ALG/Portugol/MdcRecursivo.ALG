algoritmo "MDC_Recursivo_Euclides"
var
    a, b, resultado: inteiro

// FunÁ„o recursiva para calcular o MDC
funcao inteiro mdc(inteiro x, inteiro y)
inicio
    // Caso base: se y for zero, o MDC ť x
    se (y = 0) entao
        retorne x
    fimse

    // Chamada recursiva: mdc(y, x mod y)
    retorne mdc(y, x % y)
fimfuncao

inicio
    escreva("Digite o primeiro nķmero inteiro: ")
    leia(a)

    escreva("Digite o segundo nķmero inteiro: ")
    leia(b)

    // Garantir que os nķmeros sejam positivos para evitar problemas
    se (a < 0) entao
        a := -a
    fimse
    se (b < 0) entao
        b := -b
    fimse

    resultado := mdc(a, b)

    escreval("O MDC de ", a, " e ", b, " ť: ", resultado)
fimalgoritmo
