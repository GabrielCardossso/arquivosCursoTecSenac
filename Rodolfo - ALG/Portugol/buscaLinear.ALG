algoritmo "buscaLinear"

Var
vet: vetor[1..100] de inteiro
n, i, valor: inteiro

Inicio

escreval("Digite a quantidade de números (max100): ")
leia(n)
escreval("Informe todos os valores em ordem crescente")
para i de 1 ate n faca
escreval("Digite o valor da posiçăo ", i, ": ")
leia(vet[i])
fimpara
escreval("Informe o valor a ser buscado")
leia(valor)
i <- 1
enquanto (i <= n) e (vet[i]<>valor) faca
i <- i+1
fimenquanto

se i>n entao
escreval("Valor năo encontrado")
senao
escreval("Valor encontrado na posiçăo ", i)
fimse
fimalgoritmo